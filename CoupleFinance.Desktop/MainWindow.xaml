<Window x:Class="CoupleFinance.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Couple Finance"
        Width="1540"
        Height="960"
        MinWidth="1320"
        MinHeight="820"
        Icon="Assets/AppIcon.ico"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        StateChanged="Window_OnStateChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="WindowFrame"
            Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrushStrong}"
            BorderThickness="1"
            CornerRadius="28"
            TextOptions.TextFormattingMode="Display"
            TextOptions.TextRenderingMode="ClearType"
            RenderOptions.ClearTypeHint="Enabled">
        <Grid ClipToBounds="True">
            <ContentControl Content="{Binding CurrentViewModel}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch" />

            <Grid Margin="14,10,14,0"
                  Height="42"
                  VerticalAlignment="Top"
                  Panel.ZIndex="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Height="42"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        CornerRadius="18"
                        MouseLeftButtonDown="DragSurface_OnMouseLeftButtonDown" />

                <Border Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Padding="6"
                        Background="{StaticResource CardBrushStrong}"
                        BorderBrush="{StaticResource BorderBrushStrong}"
                        BorderThickness="1"
                        CornerRadius="18"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel Orientation="Horizontal">
                        <Button Margin="0,0,4,0"
                                Style="{StaticResource WindowControlButtonStyle}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="MinimizeButton_OnClick"
                                ToolTip="Minimizar">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       Text="&#xE921;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>

                        <Button Margin="0,0,4,0"
                                Style="{StaticResource WindowControlButtonStyle}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="MaximizeRestoreButton_OnClick"
                                ToolTip="Maximizar ou restaurar">
                            <TextBlock x:Name="MaximizeGlyph"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       Text="&#xE922;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>

                        <Button Style="{StaticResource WindowCloseButtonStyle}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="CloseButton_OnClick"
                                ToolTip="Fechar">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       Text="&#xE8BB;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
