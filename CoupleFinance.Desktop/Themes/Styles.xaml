<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
    </Style>

    <Style TargetType="{x:Type Control}">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
    </Style>

    <Style TargetType="{x:Type materialDesign:PackIcon}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize" Value="40" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SectionSubtitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="EyebrowTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize" Value="29" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="CardSubtitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="MetricValueStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="ExtraBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="MetricCaptionStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="FormLabelStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="MetricCardStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="22" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.36" Color="#AA080B10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource MetricCardStyle}">
        <Setter Property="Margin" Value="0,0,0,18" />
    </Style>

    <Style x:Key="HeroCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource MetricCardStyle}">
        <Setter Property="Background" Value="{StaticResource CardBrushStrong}" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="36" ShadowDepth="0" Opacity="0.42" Color="#B0080B10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VintageHeroCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource HeroCardStyle}">
        <Setter Property="Background" Value="{StaticResource VintageHeroBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderAccentBrush}" />
    </Style>

    <Style x:Key="IncomeMetricCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource MetricCardStyle}">
        <Setter Property="Background" Value="{StaticResource IncomeMetricBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PositiveBrush}" />
    </Style>

    <Style x:Key="ExpenseMetricCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource MetricCardStyle}">
        <Setter Property="Background" Value="{StaticResource ExpenseMetricBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource NegativeBrush}" />
    </Style>

    <Style x:Key="BalanceMetricCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource MetricCardStyle}">
        <Setter Property="Background" Value="{StaticResource BalanceMetricBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
    </Style>

    <Style x:Key="InvoiceMetricCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource MetricCardStyle}">
        <Setter Property="Background" Value="{StaticResource InvoiceMetricBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InfoBrush}" />
    </Style>

    <Style x:Key="IncomeSummaryMetricCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource IncomeMetricCardStyle}">
        <Setter Property="Width" Value="282" />
        <Setter Property="MinWidth" Value="252" />
        <Setter Property="Height" Value="164" />
        <Setter Property="Margin" Value="0,0,18,18" />
    </Style>

    <Style x:Key="ExpenseSummaryMetricCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource ExpenseMetricCardStyle}">
        <Setter Property="Width" Value="282" />
        <Setter Property="MinWidth" Value="252" />
        <Setter Property="Height" Value="164" />
        <Setter Property="Margin" Value="0,0,18,18" />
    </Style>

    <Style x:Key="BalanceSummaryMetricCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource BalanceMetricCardStyle}">
        <Setter Property="Width" Value="282" />
        <Setter Property="MinWidth" Value="252" />
        <Setter Property="Height" Value="164" />
        <Setter Property="Margin" Value="0,0,18,18" />
    </Style>

    <Style x:Key="InvoiceSummaryMetricCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource InvoiceMetricCardStyle}">
        <Setter Property="Width" Value="282" />
        <Setter Property="MinWidth" Value="252" />
        <Setter Property="Height" Value="164" />
        <Setter Property="Margin" Value="0,0,18,18" />
    </Style>

    <Style x:Key="ResponsiveMainGlassCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource GlassCardStyle}">
        <Setter Property="Width" Value="720" />
        <Setter Property="MinWidth" Value="340" />
        <Setter Property="Margin" Value="0,0,18,18" />
    </Style>

    <Style x:Key="ResponsiveSideGlassCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource GlassCardStyle}">
        <Setter Property="Width" Value="470" />
        <Setter Property="MinWidth" Value="320" />
        <Setter Property="Margin" Value="0,0,18,18" />
    </Style>

    <Style x:Key="ResponsiveMainColumnStyle" TargetType="{x:Type StackPanel}">
        <Setter Property="Width" Value="720" />
        <Setter Property="MinWidth" Value="340" />
        <Setter Property="Margin" Value="0,0,18,18" />
    </Style>

    <Style x:Key="ResponsiveSideColumnStyle" TargetType="{x:Type StackPanel}">
        <Setter Property="Width" Value="470" />
        <Setter Property="MinWidth" Value="320" />
        <Setter Property="Margin" Value="0,0,18,18" />
    </Style>

    <Style x:Key="InnerCardStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="BorderBrush" Value="#35F1E2D6" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="SubtlePanelStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource InnerCardStyle}">
        <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="CornerRadius" Value="18" />
    </Style>

    <Style x:Key="ToolbarChipStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Margin" Value="0,0,10,0" />
    </Style>

    <Style x:Key="ToolbarComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Root"
                            Margin="4,2"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SidebarSelectedBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToolbarComboBoxToggleStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToolbarComboBoxStyle" TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,10,40,10" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource ToolbarComboBoxItemStyle}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <Grid>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                                <TextBlock Margin="0,0,14,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           IsHitTestVisible="False"
                                           Text="&#xE70D;" />
                                <ToggleButton x:Name="DropDownToggle"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              Focusable="False"
                                              ClickMode="Press"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Style="{StaticResource ToolbarComboBoxToggleStyle}" />
                            </Grid>
                        </Border>

                        <Popup x:Name="Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               PopupAnimation="Fade">
                            <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Margin="0,8,0,0"
                                        Background="{StaticResource CardBrushStrong}"
                                        BorderBrush="{StaticResource BorderBrushStrong}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="6">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                  CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource InputFocusBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource InputFocusBorderBrush}" />
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                        </Trigger>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="MinHeight" Value="48" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource ToolbarComboBoxStyle}">
        <Setter Property="Padding" Value="14,10,40,10" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="EmptyStateCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource InnerCardStyle}">
        <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="MinHeight" Value="180" />
    </Style>

    <Style x:Key="SidebarButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="18"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource SidebarSelectedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AccentContainedButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextOnAccentBrush}" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="MinWidth" Value="150" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrushStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.24" Color="#7AF4D38A" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="18"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBrushStrong}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#FFFFD278" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource AccentContainedButtonStyle}">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderAccentBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource SidebarHoverBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SubtleButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="Background" Value="{StaticResource SidebarHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource SidebarSelectedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ToolbarIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SubtleButtonStyle}">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="PaletteSwatchStyle" TargetType="{x:Type Border}">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="BorderBrush" Value="#33FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <Style x:Key="WindowControlButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource SidebarHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WindowCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource WindowControlButtonStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="Background" Value="#30FF7E7E" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#46FF7E7E" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ScrollBarPageButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="Background" Value="{StaticResource ScrollThumbBrush}" />
        <Setter Property="BorderBrush" Value="#12000000" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="999"
                            Margin="1" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource ScrollThumbHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource ScrollThumbPressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Width="{TemplateBinding Width}"
              Margin="0,2,0,2"
              Background="Transparent"
              SnapsToDevicePixels="True">
            <Border Margin="2,0"
                    Background="{StaticResource ScrollTrackBrush}"
                    BorderBrush="{StaticResource ScrollTrackBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="999">
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                      CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                      Style="{StaticResource ScrollBarPageButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollThumbStyle}" MinHeight="44" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                      CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                      Style="{StaticResource ScrollBarPageButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Height="{TemplateBinding Height}"
              Margin="2,0,2,0"
              Background="Transparent"
              SnapsToDevicePixels="True">
            <Border Margin="0,2"
                    Background="{StaticResource ScrollTrackBrush}"
                    BorderBrush="{StaticResource ScrollTrackBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="999">
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}"
                                      CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                      Style="{StaticResource ScrollBarPageButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollThumbStyle}" MinWidth="44" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}"
                                      CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                      Style="{StaticResource ScrollBarPageButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Width" Value="14" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="14" />
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="materialDesign:HintAssist.Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="materialDesign:HintAssist.HintOpacity" Value="0.92" />
    </Style>

    <Style TargetType="{x:Type PasswordBox}" BasedOn="{StaticResource {x:Type PasswordBox}}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="materialDesign:HintAssist.Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="materialDesign:HintAssist.HintOpacity" Value="0.92" />
    </Style>

    <Style TargetType="{x:Type DatePicker}" BasedOn="{StaticResource {x:Type DatePicker}}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="MinHeight" Value="48" />
    </Style>

    <Style TargetType="{x:Type ProgressBar}">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="Background" Value="{StaticResource SurfaceSubtleBrush}" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Margin" Value="0,10,0,0" />
    </Style>

    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="{StaticResource SurfaceAltBrush}" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource CardBrush}" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
    </Style>

    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style TargetType="{x:Type DataGridRow}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="MinHeight" Value="46" />
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style TargetType="{x:Type ScrollViewer}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
</ResourceDictionary>
