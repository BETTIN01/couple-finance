<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
    <FontFamily x:Key="DisplayFont">Cambria</FontFamily>

    <Color x:Key="VintageNeutralColor">#FFD8D8D8</Color>
    <Color x:Key="VintageTealColor">#FF488399</Color>
    <Color x:Key="VintageCoralColor">#FFEA9393</Color>
    <Color x:Key="VintageGoldColor">#FFF4D38A</Color>
    <Color x:Key="VintageBlushColor">#FFF1BEBE</Color>

    <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF12181B" Offset="0" />
        <GradientStop Color="#FF1D343B" Offset="0.34" />
        <GradientStop Color="#FF2F252C" Offset="0.78" />
        <GradientStop Color="#FF181416" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ShellSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F01C272C" Offset="0" />
        <GradientStop Color="#EE243238" Offset="0.52" />
        <GradientStop Color="#EB2A2329" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SidebarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F021353D" Offset="0" />
        <GradientStop Color="#EF1B2930" Offset="0.58" />
        <GradientStop Color="#F02A2028" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="#3E488399" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#26488399" />

    <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E826353C" Offset="0" />
        <GradientStop Color="#E92C3B42" Offset="0.48" />
        <GradientStop Color="#E8362931" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardBrushStrong" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F02E434C" Offset="0" />
        <GradientStop Color="#EE38505A" Offset="0.5" />
        <GradientStop Color="#EA4A353F" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SurfaceAltBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#A1243941" Offset="0" />
        <GradientStop Color="#A32B3E47" Offset="0.5" />
        <GradientStop Color="#A6342A33" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SurfaceHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#BD2C4753" Offset="0" />
        <GradientStop Color="#BF37515E" Offset="0.52" />
        <GradientStop Color="#BF493741" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SurfaceSubtleBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#7F22353D" Offset="0" />
        <GradientStop Color="#82283A43" Offset="0.5" />
        <GradientStop Color="#842F2630" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="InputBrush" Color="#D11C2A2F" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#47A7B0B4" />
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#90F4D38A" />
    <LinearGradientBrush x:Key="ChartSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#A5213138" Offset="0" />
        <GradientStop Color="#A8253640" Offset="0.45" />
        <GradientStop Color="#A42E2731" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ChartGridBrush" Color="#3E6170" />
    <SolidColorBrush x:Key="InsetOverlayBrush" Color="#33111418" />
    <SolidColorBrush x:Key="BusyOverlayBrush" Color="#7A111519" />
    <SolidColorBrush x:Key="ScrollTrackBrush" Color="#46F4EEE7" />
    <SolidColorBrush x:Key="ScrollTrackBorderBrush" Color="#00FFFFFF" />
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#FF232629" />
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#FF2C3034" />
    <SolidColorBrush x:Key="ScrollThumbPressedBrush" Color="#FF363B40" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource VintageGoldColor}" />
    <LinearGradientBrush x:Key="AccentBrushStrong" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF7DFA4" Offset="0" />
        <GradientStop Color="#FFF0C66E" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#33F4D38A" />

    <SolidColorBrush x:Key="PositiveBrush" Color="{StaticResource VintageTealColor}" />
    <SolidColorBrush x:Key="PositiveSoftBrush" Color="#24488399" />
    <SolidColorBrush x:Key="NegativeBrush" Color="{StaticResource VintageCoralColor}" />
    <SolidColorBrush x:Key="NegativeSoftBrush" Color="#29EA9393" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource VintageGoldColor}" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="#26F4D38A" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource VintageBlushColor}" />
    <SolidColorBrush x:Key="InfoSoftBrush" Color="#23F1BEBE" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF9F1E8" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFEADCCF" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#FFD2C0B1" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#FFAA9D92" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FF3B332A" />

    <SolidColorBrush x:Key="BorderBrushStrong" Color="#42F1E2D6" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#25E7D8CB" />
    <SolidColorBrush x:Key="BorderAccentBrush" Color="#55F4D38A" />

    <LinearGradientBrush x:Key="VintageHeroBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF25404A" Offset="0" />
        <GradientStop Color="#F03B5662" Offset="0.48" />
        <GradientStop Color="#C56D4D55" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="IncomeMetricBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5A488399" Offset="0" />
        <GradientStop Color="#E1222E33" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ExpenseMetricBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#52EA9393" Offset="0" />
        <GradientStop Color="#E1272D31" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BalanceMetricBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#56F4D38A" Offset="0" />
        <GradientStop Color="#E1292C2E" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="InvoiceMetricBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#51F1BEBE" Offset="0" />
        <GradientStop Color="#E12B2A31" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="VintageNeutralBrush" Color="{StaticResource VintageNeutralColor}" />
    <SolidColorBrush x:Key="VintageTealBrush" Color="{StaticResource VintageTealColor}" />
    <SolidColorBrush x:Key="VintageCoralBrush" Color="{StaticResource VintageCoralColor}" />
    <SolidColorBrush x:Key="VintageGoldBrush" Color="{StaticResource VintageGoldColor}" />
    <SolidColorBrush x:Key="VintageBlushBrush" Color="{StaticResource VintageBlushColor}" />
</ResourceDictionary>
