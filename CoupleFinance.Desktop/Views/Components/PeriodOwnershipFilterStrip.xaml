<UserControl x:Class="CoupleFinance.Desktop.Views.Components.PeriodOwnershipFilterStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <DataTemplate x:Key="EnumComboTemplate">
            <TextBlock Text="{Binding Converter={StaticResource EnumDisplayConverter}}" />
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource SubtlePanelStyle}"
            Padding="12,10">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{Binding PreviousPeriodCommand}"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Width="40"
                    Height="40">
                <materialDesign:PackIcon Kind="ChevronLeft"
                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            </Button>

            <Border Grid.Column="1"
                    Style="{StaticResource ToolbarChipStyle}"
                    Margin="8,0"
                    Padding="12,8"
                    CornerRadius="14"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding PeriodLabel}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </Border>

            <Button Grid.Column="2"
                    Command="{Binding NextPeriodCommand}"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Width="40"
                    Height="40">
                <materialDesign:PackIcon Kind="ChevronRight"
                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            </Button>

            <ComboBox Grid.Column="4"
                      MinWidth="120"
                      Style="{StaticResource ToolbarComboBoxStyle}"
                      MinHeight="40"
                      Padding="14,8,36,8"
                      VerticalContentAlignment="Center"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding PeriodPresets}"
                      ItemTemplate="{StaticResource EnumComboTemplate}"
                      SelectedItem="{Binding SelectedPeriod}" />

            <ComboBox Grid.Column="6"
                      MinWidth="160"
                      Style="{StaticResource ToolbarComboBoxStyle}"
                      MinHeight="40"
                      Padding="14,8,36,8"
                      VerticalContentAlignment="Center"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding OwnershipFilters}"
                      ItemTemplate="{StaticResource EnumComboTemplate}"
                      SelectedItem="{Binding SelectedOwnership}" />
        </Grid>
    </Border>
</UserControl>
