<UserControl x:Class="CoupleFinance.Desktop.Views.Pages.ShellPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:CoupleFinance.Desktop.Views.Pages"
             xmlns:presentation="clr-namespace:CoupleFinance.Desktop.Presentation">
    <Grid Margin="6,0,6,6">
        <Border Background="{StaticResource ShellSurfaceBrush}"
                CornerRadius="32"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="1">
            <Grid ClipToBounds="True">
                <Border Height="6"
                        VerticalAlignment="Top"
                        CornerRadius="32,32,0,0"
                        Background="{StaticResource VintageHeroBrush}"
                        Opacity="0.95" />

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SidebarColumn" Width="264" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="SidebarHost"
                            Background="{StaticResource SidebarBrush}"
                            CornerRadius="32,0,0,32"
                            Padding="20,22,18,18">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      presentation:SmoothScrollBehavior.Enable="True"
                                      presentation:SmoothScrollBehavior.WheelChange="72"
                                      presentation:SmoothScrollBehavior.Duration="0:0:0.22">
                            <StackPanel>
                                <StackPanel>
                                    <TextBlock x:Name="BrandTitleText"
                                               Text="Couple Finance"
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontSize="26"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="SidebarBrandSubtitle"
                                               Text="Organizacao financeira feita para decisoes em casal."
                                               Style="{StaticResource CardSubtitleStyle}"
                                               Margin="0,8,0,0" />
                                    <StackPanel x:Name="PaletteRow"
                                                Orientation="Horizontal"
                                                Margin="0,16,0,0">
                                        <Border Style="{StaticResource PaletteSwatchStyle}" Background="{StaticResource VintageNeutralBrush}" />
                                        <Border Style="{StaticResource PaletteSwatchStyle}" Background="{StaticResource VintageTealBrush}" />
                                        <Border Style="{StaticResource PaletteSwatchStyle}" Background="{StaticResource VintageCoralBrush}" />
                                        <Border Style="{StaticResource PaletteSwatchStyle}" Background="{StaticResource VintageGoldBrush}" />
                                        <Border Style="{StaticResource PaletteSwatchStyle}" Background="{StaticResource VintageBlushBrush}" Margin="0" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel x:Name="SidebarNavigationPanel"
                                            Margin="0,0,0,10">
                                    <Button Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Dashboard">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ViewDashboard"
                                                                     Margin="0,0,12,0"
                                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            <TextBlock Text="Dashboard"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Transactions">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="SwapHorizontalBold"
                                                                     Margin="0,0,12,0"
                                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            <TextBlock Text="Movimentacoes"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Accounts">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="BankOutline"
                                                                     Margin="0,0,12,0"
                                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            <TextBlock Text="Contas"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Cards">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CreditCardOutline"
                                                                     Margin="0,0,12,0"
                                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            <TextBlock Text="Cartoes"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Planning">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="BullseyeArrow"
                                                                     Margin="0,0,12,0"
                                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            <TextBlock Text="Planejamento"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Investments">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ChartTimelineVariant"
                                                                     Margin="0,0,12,0"
                                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            <TextBlock Text="Investimentos"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Insights">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="LightbulbAutoOutline"
                                                                     Margin="0,0,12,0"
                                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            <TextBlock Text="Insights"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SidebarButtonStyle}"
                                            Command="{Binding NavigateCommand}"
                                            CommandParameter="Settings">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CogOutline"
                                                                     Margin="0,0,12,0"
                                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            <TextBlock Text="Configuracoes"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <Border x:Name="AccountCard"
                                        Style="{StaticResource SubtlePanelStyle}"
                                        Margin="0,6,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Sua conta" Style="{StaticResource EyebrowTextStyle}" />
                                        <TextBlock Text="{Binding CurrentSnapshot.CurrentUser.DisplayName}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding CurrentSnapshot.CurrentUser.Email}"
                                                   Style="{StaticResource CardSubtitleStyle}"
                                                   Margin="0,6,0,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   ToolTip="{Binding CurrentSnapshot.CurrentUser.Email}" />
                                        <Button Command="{Binding SignOutCommand}"
                                                Style="{StaticResource SubtleButtonStyle}"
                                                HorizontalAlignment="Left"
                                                Margin="0,14,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Logout"
                                                                         Margin="0,0,8,0"
                                                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                <TextBlock Text="Sair"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Grid x:Name="MainContentHost"
                          Grid.Column="1"
                          Margin="20,50,20,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="HeaderLayoutGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel x:Name="HeaderTitlePanel"
                                        Margin="0,0,18,0">
                                <Border x:Name="ShellHeaderBar"
                                        Width="104"
                                        Height="8"
                                        Background="{StaticResource VintageHeroBrush}"
                                        CornerRadius="4"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,10" />
                                <TextBlock x:Name="SectionTitleText"
                                           Text="{Binding SectionTitle}"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock x:Name="SectionSubtitleText"
                                           Text="{Binding SectionSubtitle}"
                                           Style="{StaticResource SectionSubtitleStyle}"
                                           Margin="0,6,0,0" />
                            </StackPanel>

                            <Border x:Name="UpdateStatusChip"
                                    Grid.Row="1"
                                    Style="{StaticResource ToolbarChipStyle}"
                                    Background="{StaticResource WarningSoftBrush}"
                                    BorderBrush="{StaticResource WarningBrush}"
                                    Padding="12,8"
                                    CornerRadius="14"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding Updater.IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="Atualizacoes: " FontWeight="SemiBold" />
                                    <Run Text="{Binding Updater.StatusText}" />
                                </TextBlock>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,16,0,0">
                            <ScrollViewer x:Name="SectionScrollViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          presentation:SmoothScrollBehavior.Enable="True"
                                          presentation:SmoothScrollBehavior.WheelChange="112"
                                          presentation:SmoothScrollBehavior.Duration="0:0:0.24">
                                <Grid x:Name="SectionContentHost"
                                      HorizontalAlignment="Stretch">
                                    <local:DashboardPage Visibility="{Binding CurrentSection, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Dashboard}" />
                                    <local:TransactionsPage Visibility="{Binding CurrentSection, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Transactions}" />
                                    <local:AccountsPage Visibility="{Binding CurrentSection, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Accounts}" />
                                    <local:CardsPage Visibility="{Binding CurrentSection, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Cards}" />
                                    <local:PlanningPage Visibility="{Binding CurrentSection, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Planning}" />
                                    <local:InvestmentsPage Visibility="{Binding CurrentSection, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Investments}" />
                                    <local:InsightsPage Visibility="{Binding CurrentSection, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Insights}" />
                                    <local:SettingsPage Visibility="{Binding CurrentSection, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Settings}" />
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <Border Grid.RowSpan="2"
                                Background="{StaticResource BusyOverlayBrush}"
                                CornerRadius="24"
                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Panel.ZIndex="10">
                            <Border Style="{StaticResource VintageHeroCardStyle}"
                                    Width="320"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="24">
                                <StackPanel>
                                    <ProgressBar IsIndeterminate="True" Height="6" Margin="0,0,0,16" />
                                    <TextBlock Text="Atualizando sua visao financeira" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="O app esta recalculando saldos, graficos e recomendacoes do periodo."
                                               Style="{StaticResource CardSubtitleStyle}"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </Border>

                        <Border Grid.RowSpan="2"
                                Background="{StaticResource BusyOverlayBrush}"
                                CornerRadius="24"
                                Visibility="{Binding IsUpdatePromptVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Panel.ZIndex="11">
                            <Border x:Name="UpdatePromptDialog"
                                    Style="{StaticResource VintageHeroCardStyle}"
                                    Width="520"
                                    MaxWidth="520"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="24"
                                    Padding="24">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="UpdatePromptDialogTransform" />
                                </Border.RenderTransform>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="UpdatePromptDragHandle"
                                            Grid.ColumnSpan="2"
                                            Background="Transparent"
                                            CornerRadius="16"
                                            Cursor="Hand"
                                            Padding="0,0,42,0"
                                            ToolTip="Arraste para mover"
                                            PreviewMouseLeftButtonDown="UpdatePromptDragHandle_OnMouseLeftButtonDown"
                                            PreviewMouseMove="UpdatePromptDragHandle_OnMouseMove"
                                            PreviewMouseLeftButtonUp="UpdatePromptDragHandle_OnMouseLeftButtonUp"
                                            LostMouseCapture="UpdatePromptDragHandle_OnLostMouseCapture">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding UpdatePromptTitle}"
                                                       Style="{StaticResource CardTitleStyle}"
                                                       FontSize="24"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="Sua nova versao ja esta pronta para entrar em cena."
                                                       Style="{StaticResource CardSubtitleStyle}"
                                                       Margin="0,8,0,0"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <Button Grid.Column="1"
                                            Width="34"
                                            Height="34"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Command="{Binding DismissUpdatePromptCommand}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top">
                                        <materialDesign:PackIcon Kind="Close"
                                                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </Button>

                                    <Border Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Style="{StaticResource InnerCardStyle}"
                                            Background="{StaticResource SurfaceSubtleBrush}"
                                            Margin="0,18,0,0">
                                        <StackPanel HorizontalAlignment="Center"
                                                    MaxWidth="392">
                                            <Border Width="56"
                                                    Height="56"
                                                    CornerRadius="18"
                                                    Background="{StaticResource WarningSoftBrush}"
                                                    BorderBrush="{StaticResource WarningBrush}"
                                                    BorderThickness="1"
                                                    HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="DownloadCircleOutline"
                                                                         Width="28"
                                                                         Height="28"
                                                                         Foreground="{StaticResource WarningBrush}"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center" />
                                            </Border>

                                            <TextBlock
                                                       Text="{Binding UpdatePromptMessage}"
                                                       TextWrapping="Wrap"
                                                       FontSize="17"
                                                       LineHeight="26"
                                                       Margin="0,16,0,0"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Row="2"
                                                Grid.ColumnSpan="2"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,20,0,0">
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DismissUpdatePromptCommand}"
                                                Content="Depois"
                                                Margin="0,0,10,0"
                                                MinWidth="128" />
                                        <Button Style="{StaticResource AccentContainedButtonStyle}"
                                                Command="{Binding ApplyPreparedUpdatePromptCommand}"
                                                Content="Reiniciar agora"
                                                MinWidth="164"
                                                Background="{StaticResource AccentBrushStrong}"
                                                Foreground="{StaticResource TextOnAccentBrush}"
                                                TextElement.Foreground="{StaticResource TextOnAccentBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
