<Application x:Class="CoupleFinance.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CoupleFinance.Desktop.Converters"
             xmlns:viewModels="clr-namespace:CoupleFinance.Desktop.ViewModels"
             xmlns:views="clr-namespace:CoupleFinance.Desktop.Views.Pages"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="BlueGrey" SecondaryColor="Amber" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
                <ResourceDictionary Source="/Themes/Colors.xaml" />
                <ResourceDictionary Source="/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
            <converters:EnumDisplayConverter x:Key="EnumDisplayConverter" />
            <converters:CurrencyColorConverter x:Key="CurrencyColorConverter" />
            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <converters:TextToVisibilityConverter x:Key="TextToVisibilityConverter" />
            <converters:BooleanMatchToVisibilityConverter x:Key="BooleanMatchToVisibilityConverter" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <DataTemplate DataType="{x:Type viewModels:AuthViewModel}">
                <views:AuthPage />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:ShellViewModel}">
                <views:ShellPage />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
